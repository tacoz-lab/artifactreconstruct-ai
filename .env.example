# Backend runtime configuration
GEMINI_API_KEY=your_gemini_api_key_here
PORT=8787
# Optional, comma-separated list for production CORS restriction.
# Example: https://tacoz-lab.github.io,http://localhost:3000
ALLOWED_ORIGINS=

# Frontend build-time configuration
# For GitHub Pages production builds, set this to your deployed backend origin, e.g.
# VITE_API_BASE_URL=https://artifactreconstruct-api.your-domain.com
VITE_API_BASE_URL=
